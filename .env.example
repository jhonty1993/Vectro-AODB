# HTTP port (Railway sets PORT automatically)
PORT=8080

# Admin API key for protected console actions (optional)
ADMIN_API_KEY=change-me-admin-key

# Airline portal API keys — JSON map of airline IATA code → secret key
# Airlines send: Authorization: Bearer <key>
PORTAL_API_KEYS={"AC":"your-air-canada-key","WS":"your-westjet-key","PD":"your-porter-key"}

# Set to production in Railway to disable demo portal keys
NODE_ENV=production
